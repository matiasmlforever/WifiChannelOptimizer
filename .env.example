# ─────────────────────────────────────────────────────────────────────────────
# WiFi Channel Optimizer — environment configuration
# Copy this file to ".env" and fill in your values.
# NEVER commit ".env" to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Router admin credentials
ROUTER_URL=http://192.168.100.1
ROUTER_USER=admin
ROUTER_PASS=admin

# Scanning & daemon
SCAN_INTERVAL_SECONDS=300

# Post-change quality monitoring
TRIAL_PERIOD_SECONDS=1800
PING_DEGRADATION_MS=100
SPEED_DEGRADATION_PCT=0.40
