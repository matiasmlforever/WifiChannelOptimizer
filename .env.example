# ─────────────────────────────────────────────────────────────────────────────
# WiFi Channel Optimizer — environment configuration
# Copy this file to ".env" and fill in your values.
# NEVER commit ".env" to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Router admin credentials
ROUTER_URL=http://192.168.100.1
ROUTER_USER=admin
ROUTER_PASS=admin

# Router driver — selects the automation implementation for your router model.
# Available built-in drivers:
#   huawei_hg8145x6   (default) — Huawei HG8145X6, tested with Entel ISP Chile
# To add a new model: subclass BaseRouter in wifi_optimizer/routers/<model>.py
# and register it in the ROUTER_DRIVERS dict in main.py.
ROUTER_DRIVER=huawei_hg8145x6

# ── Scanning & daemon ─────────────────────────────────────────────────────────
# How often to re-scan the RF environment (seconds).
# Cheap — only runs netsh, never contacts the router.
SCAN_INTERVAL_SECONDS=300

# ── Normal mode (inside high-congestion windows from --analyze) ───────────────
# Optimizer acts when it detects a congested hour AND the baseline is degraded.

# Baseline quality guard — skip if connection is already good.
# Both conditions must hold to skip: ping ≤ X AND jitter ≤ Y.
# Empirical: all 3 real reverts happened when baseline was already good.
BASELINE_GOOD_PING_MS=15
BASELINE_GOOD_JITTER_MS=5

# Minimum time between router channel changes (seconds).
CHANGE_COOLDOWN_SECONDS=3600

# Minimum relative RF improvement required to trigger a change.
# 0.40 = 40% — only switch if the new channel is dramatically less congested.
HYSTERESIS_THRESHOLD=0.40

# ── Emergency mode (outside optimal windows, e.g. gaming hours) ──────────────
# During low-congestion hours the optimizer stays silent UNLESS the signal
# degrades severely enough to ruin an active gaming session.
#
# Mini selector:
#   GAMING_PROFILE=balanced   -> 40/20/0.50/3600
#   GAMING_PROFILE=aggressive -> 30/12/0.35/1800
# Explicit EMERGENCY_* values override the selected profile.
GAMING_PROFILE=balanced
#
# Only acts if: ping > EMERGENCY_PING_MS  OR  jitter > EMERGENCY_JITTER_MS
# Uses a much higher RF improvement threshold to avoid interrupting a session
# unless the channel change is truly dramatic.
# Longer cooldown avoids repeated restarts during a match.
EMERGENCY_PING_MS=40
EMERGENCY_JITTER_MS=20
EMERGENCY_HYSTERESIS=0.50
EMERGENCY_COOLDOWN_SECONDS=3600

# Optional manual override for aggressive response outside optimal windows.
# Usually not needed if you set GAMING_PROFILE=aggressive.
# EMERGENCY_PING_MS=30
# EMERGENCY_JITTER_MS=12
# EMERGENCY_HYSTERESIS=0.35
# EMERGENCY_COOLDOWN_SECONDS=1800

# ── Post-change quality monitoring (gaming-tuned defaults) ───────────────────
# How long to wait after a channel change before evaluating quality (seconds).
TRIAL_PERIOD_SECONDS=300

# Gateway RTT increase (ms) that triggers a channel revert.
# 20 ms is noticeable in competitive gaming (target: <5 ms to gateway).
PING_DEGRADATION_MS=20

# Jitter increase (ms) that triggers a revert.
# 15 ms of extra jitter causes rubber-banding in most games.
JITTER_DEGRADATION_MS=15

# Download speed drop fraction that triggers a revert (secondary signal).
SPEED_DEGRADATION_PCT=0.40
